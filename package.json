{
  "name": "worktrack",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate:diagram": "depcruise src --output-type dot | dot -T svg > docs/architecture/diagrams/dependency-graph.svg",
    "diagram:system": "depcruise src backend --output-type dot | dot -Tsvg -o docs/architecture/diagrams/system.svg",
    "diagram:src": "depcruise src --output-type dot | dot -Tsvg -o docs/architecture/diagrams/src-dependencies.svg",
    "diagram:backend": "depcruise backend --output-type dot | dot -Tsvg -o docs/architecture/diagrams/backend-dependencies.svg",
    "diagram:layers": "depcruise src backend --output-type dot --collapse '^(src|backend)/[^/]+' | dot -Tsvg -o docs/architecture/diagrams/layers.svg",
    "generate:diagrams": "npm run diagram:system && npm run diagram:src && npm run diagram:backend && npm run diagram:layers",
    "docs:refresh": "npm run generate:diagram",
    "generate:c4": "docker run --rm -v $(pwd):/workspace -w /workspace structurizr/cli export -workspace architecture/c4/worktrak.dsl -format plantuml -output docs/architecture/c4",
    "c4:export": "structurizr export -workspace architecture/c4/worktrak.dsl -format plantuml -output docs/architecture/c4",
    "c4:render": "plantuml docs/architecture/c4/*.puml",
    "c4": "npm run c4:export && npm run c4:render"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.3.0",
    "lucide-react": "^0.575.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-responsive": "^10.0.1",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
